# Database (used by API and Prisma)
# host=localhost, user=test_user, password=test_password, dbname=Bharatathlete, port=5432, sslmode=disable
DATABASE_URL=postgresql://test_user:test_password@localhost:5432/Bharatathlete?sslmode=disable

# JWT secret (must match between Next.js and API for session token)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# NextAuth (Next.js) – required for login; copy to apps/web/.env or set when running web app
# Use port 3000 if using "pnpm dev:web", or 3002 if using "pnpm dev:web:alt"
# If you change NEXTAUTH_SECRET, clear site cookies for localhost or use a private window to avoid JWT decryption errors.
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-change-in-production

# API URL (from browser and Next.js server). Use 127.0.0.1 if login is slow (avoids IPv6 localhost on Windows)
NEXT_PUBLIC_API_URL=http://127.0.0.1:3001

# Optional: Redis (MVP uses in-memory cache; set REDIS_URL to use Redis)
# REDIS_URL=redis://localhost:6379

# API server port (default 3001)
# PORT=3001

# Public app URL (sitemap, etc.)
APP_URL=http://localhost:3000

# Razorpay (billing) – get keys from https://dashboard.razorpay.com
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...
# Optional: set in apps/web for client-side Razorpay Checkout (key only, not secret)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_...
